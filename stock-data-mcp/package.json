{
  "name": "z-mcp-stock-data-server",
  "version": "0.1.0",
  "private": true,
  "description": "Personal MCP stock data server focused on ETF quote, kline, analysis, and list tools.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "report:score-calibration": "tsx scripts/score-calibration-report.ts",
    "start": "node dist/index.js",
    "test": "node --import tsx --test tests/**/*.test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.1",
    "mysql2": "^3.22.3",
    "playwright": "^1.55.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
